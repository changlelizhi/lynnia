<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="space.changle.lynnia.repo.mapper.UserAccountMapper">

    <resultMap id="UserAccountResultMap" type="space.changle.lynnia.repo.entity.UserAccount">
        <id property="userId" column="user_id"/>
        <result property="status" column="status"/>
        <result property="taskReviewer" column="is_task_reviewer"/>
        <result property="banOperator" column="is_ban_operator"/>
        <result property="registerTime" column="register_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="Base_Column_List">
        user_id,
        status,
        is_task_reviewer,
        is_ban_operator,
        register_time,
        update_time
    </sql>

    <select id="selectById" resultMap="UserAccountResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_user_account
        WHERE user_id = #{userId}
    </select>

    <insert id="insertAccount" parameterType="space.changle.lynnia.repo.entity.UserAccount">
        INSERT INTO t_user_account (  user_id,
                                      status,
                                      is_task_reviewer,
                                      is_ban_operator,
                                      register_time,
                                      update_time)
        VALUES (#{userId},
                #{status},
                #{taskReviewer},
                #{banOperator},
                #{registerTime},
                #{updateTime})
    </insert>


</mapper>